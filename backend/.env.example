# Database connection URL
# Uses docker-compose configuration by default
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# JWT configuration
JWT_SECRET=your-secret-key-change-in-production-at-least-32-chars
JWT_EXPIRES_IN=7d

# AWS Configuration (Bedrock, S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_BEDROCK_REGION=us-east-1

# Amazon OpenSearch Serverless
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint.us-east-1.aoss.amazonaws.com
OPENSEARCH_USERNAME=your-opensearch-username
OPENSEARCH_PASSWORD=your-opensearch-password

# Port configurations
PORT=3001
