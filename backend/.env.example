# Database connection URL
# Uses docker-compose configuration by default
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# JWT configuration
JWT_SECRET=your-secret-key-change-in-production-at-least-32-chars
JWT_EXPIRES_IN=7d

# AWS Configuration (Bedrock, S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
AWS_BEDROCK_MAX_TOKENS=1000

# Amazon OpenSearch Serverless
OPENSEARCH_NODE=https://your-opensearch-endpoint.us-east-1.aoss.amazonaws.com
OPENSEARCH_USERNAME=your-opensearch-username
OPENSEARCH_PASSWORD=your-opensearch-password
OPENSEARCH_INDEX=document-chunks
OPENSEARCH_REJECT_UNAUTHORIZED=true
OPENSEARCH_MAX_RETRIES=3
OPENSEARCH_RETRY_DELAY=1000

# RAG Configuration
RAG_SYSTEM_PROMPT=You are a professional assistant grounded exclusively in the provided context.
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# Port configurations
PORT=3001
